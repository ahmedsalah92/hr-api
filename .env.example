# .env.example
# NODE ENVIRONMENT (development | production)
NODE_ENV=development

# POSTGRES (host, port, user, password, database name)
DB_HOST=your_db_host
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# JWT AUTH
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=3600s  # e.g. '3600s' or '1h'
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d


# Global log level (console & other transports without explicit level)
LOG_LEVEL=info

# File transport log level (only writes ≥ this level)
FILE_LOG_LEVEL=info

# File transport — path to the main app log
LOG_FILE_PATH=logs/app.log

# File transport — rotate when file size exceeds this (in bytes)
LOG_FILE_MAX_SIZE=5242880      # 5 MB

# File transport — keep this many rotated files
LOG_FILE_MAX_FILES=5

# Exception handler — path to uncaught exceptions log
EXCEPTIONS_LOG_FILE=logs/exceptions.log

# Rejection handler — path to unhandled promise rejections log
REJECTIONS_LOG_FILE=logs/rejections.log



