generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  WORK_FROM_HOME
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  passwordHash  String
  role          Role
  employeeId    String         @unique
  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  // 2FA Support
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String? // TOTP secret (base32)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
  hireDate  DateTime

  // Self-referencing manager relation
  managerId    String?
  manager      Employee?  @relation("ManagerToEmployee", fields: [managerId], references: [id])
  subordinates Employee[] @relation("ManagerToEmployee")

  // Requests submitted by this employee
  missionRequests  MissionRequest[]
  leaveRequests    LeaveRequest[]
  attendances      Attendance[]
  officeExits      OfficeExit[]
  workFromHomeDays WorkFromHome[]

  // Requests approved by this employee (manager or admin)
  approvedMissions MissionRequest[] @relation("ApprovedMissions")
  approvedLeaves   LeaveRequest[]   @relation("ApprovedLeaves")
  approvedWFH      WorkFromHome[]   @relation("ApprovedWFH")

  // Relation to auth system
  user User?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MissionRequest {
  id                      String        @id @default(uuid())
  employee                Employee      @relation(fields: [employeeId], references: [id])
  employeeId              String
  status                  RequestStatus
  locationTrackingEnabled Boolean       @default(false)
  approvedBy              Employee?     @relation("ApprovedMissions", fields: [approvedById], references: [id])
  approvedById            String?
  startDate               DateTime
  endDate                 DateTime
  reason                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeaveRequest {
  id           String        @id @default(uuid())
  employee     Employee      @relation(fields: [employeeId], references: [id])
  employeeId   String
  type         LeaveType
  status       RequestStatus
  approvedBy   Employee?     @relation("ApprovedLeaves", fields: [approvedById], references: [id])
  approvedById String?
  startDate    DateTime
  endDate      DateTime
  reason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkFromHome {
  id           String    @id @default(uuid())
  employee     Employee  @relation(fields: [employeeId], references: [id])
  employeeId   String
  date         DateTime
  approvedBy   Employee? @relation("ApprovedWFH", fields: [approvedById], references: [id])
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id         String    @id @default(uuid())
  employee   Employee  @relation(fields: [employeeId], references: [id])
  employeeId String
  date       DateTime
  checkIn    DateTime
  checkOut   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OfficeExit {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  reason     String
  exitTime   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
